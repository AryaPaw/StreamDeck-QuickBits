{
	"Name": "QuickBits",
	"Version": "0.1.0.5",
	"Author": "AryaPaw",
	"Actions": [
		{
			"Name": "Set Volume",
			"UUID": "dev.aryapaw.quickbits.set-volume",
			"Icon": "imgs/actions/set-volume/icon",
			"Tooltip": "Set system volume to a specific percentage",
			"PropertyInspectorPath": "ui/set-volume.html",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/set-volume/key", "TitleAlignment": "bottom" }]
		},
		{
			"Name": "Toggle DND",
			"UUID": "dev.aryapaw.quickbits.toggle-dnd",
			"Icon": "imgs/actions/toggle-dnd/icon",
			"Tooltip": "Toggle Windows Do Not Disturb mode",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/toggle-dnd/key", "TitleAlignment": "bottom" }]
		},
		{
			"Name": "Skydimo: lighting (foreground triggers)",
			"UUID": "dev.aryapaw.quickbits.marker-skydimo-screen-sync",
			"Icon": "imgs/actions/marker-skydimo-screen-sync/icon",
			"Tooltip": "Skydimo: tap Sync/Static; hold for Off (separate trigger)",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "imgs/actions/marker-skydimo-screen-sync/static",
					"Title": "Static",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Spotify: Setup",
			"UUID": "dev.aryapaw.quickbits.spotify-setup",
			"Icon": "imgs/actions/spotify/icon",
			"Tooltip": "Configure Spotify API credentials",
			"PropertyInspectorPath": "ui/spotify-setup.html",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/spotify/key", "TitleAlignment": "middle" }]
		},
		{
			"Name": "Spotify: Now Playing",
			"UUID": "dev.aryapaw.quickbits.spotify-now-playing",
			"Icon": "imgs/actions/spotify/play",
			"Tooltip": "Show current track, press to play/pause",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/spotify/play", "TitleAlignment": "bottom" }]
		},
		{
			"Name": "Spotify: Previous",
			"UUID": "dev.aryapaw.quickbits.spotify-previous",
			"Icon": "imgs/actions/spotify/previous",
			"Tooltip": "Previous track",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/spotify/previous" }]
		},
		{
			"Name": "Spotify: Next",
			"UUID": "dev.aryapaw.quickbits.spotify-next",
			"Icon": "imgs/actions/spotify/next",
			"Tooltip": "Next track",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/spotify/next" }]
		},
		{
			"Name": "Spotify: Like",
			"UUID": "dev.aryapaw.quickbits.spotify-like",
			"Icon": "imgs/actions/spotify/like",
			"Tooltip": "Add or remove current track from liked songs",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/spotify/like" }]
		}
	],
	"Category": "Quickbits",
	"CategoryIcon": "imgs/plugin/category-icon",
	"CodePath": "bin/plugin.js",
	"Description": "A collection of small useful actions for Stream Deck",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "dev.aryapaw.quickbits"
}