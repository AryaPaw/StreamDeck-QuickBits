{
    "scripts": {
        "build": "bun run build:helper && rollup -c",
        "build:helper": "dotnet publish helper -c Release && shx cp helper/bin/Release/net8.0-windows/win-x64/publish/QuickbitsHelper.exe dev.aryapaw.quickbits.sdPlugin/helper/",
        "build:plugin": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart dev.aryapaw.quickbits\""
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.7.3",
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.0",
        "@tsconfig/node20": "^20.1.2",
        "@types/node": "~20.15.0",
        "rollup": "^4.0.2",
        "shx": "^0.4.0",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.0.0"
    }
}